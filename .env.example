# Token del bot Telegram (ottenuto da @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Chat ID autorizzato (ottieni il tuo da @userinfobot su Telegram)
AUTHORIZED_CHAT_ID=123456789

# Nome univoco di questo PC (es. "desktop", "laptop")
MACHINE_NAME=desktop

# Timeout comandi in secondi (default: 30)
COMMAND_TIMEOUT=30

# Abilita heartbeat per peer discovery multi-PC (true/false, default: true)
# Se usi un solo PC puoi disabilitarlo con false
HEARTBEAT_ENABLED=true

# Intervallo heartbeat in secondi (default: 60, max: 3600)
# Usato solo se HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL=60

# Abilita il log di audit dei comandi eseguiti (true/false, default: true)
# Quando true, ogni comando viene scritto in chiaro in
# ~/.local/share/telegram-terminal-bot/audit.jsonl (timestamp, comando,
# exit code, durata). Vedi SECURITY.md sezione "Audit Log" per i dettagli
# di compliance prima di abilitarlo in ambienti regolamentati.
AUDIT_LOG_ENABLED=true

# Redaction opzionale dei segreti nel log di audit (true/false, default: false).
# Applica un pattern conservativo di redaction (--password=, mysql -p<pwd>,
# *_KEY/*_TOKEN/*_SECRET=, Authorization: Bearer) prima di scrivere ogni
# entry. Best-effort, NON sostituisce una vera redaction.
# Vedi SECURITY.md per i limiti — usa AUDIT_LOG_ENABLED=false se serve
# garanzia stretta di non-leakage.
AUDIT_REDACT_SECRETS=false
