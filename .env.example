# Token del bot Telegram (ottenuto da @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Chat ID autorizzato (ottieni il tuo da @userinfobot su Telegram)
AUTHORIZED_CHAT_ID=123456789

# Nome univoco di questo PC (es. "desktop", "laptop")
MACHINE_NAME=desktop

# Timeout comandi in secondi (default: 30)
COMMAND_TIMEOUT=30

# Intervallo heartbeat in secondi (default: 60)
HEARTBEAT_INTERVAL=60
